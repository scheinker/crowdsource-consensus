{
  "name": "crowdsource-consensus",
  "version": "0.3.0",
  "description": "Turn noisy crowdsourced reports into confidence-weighted status with graceful time decay",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "consensus",
    "crowdsource",
    "voting",
    "confidence",
    "decay",
    "status",
    "realtime"
  ],
  "author": "Matte Scheinker",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/scheinker/crowdsource-consensus"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
